		local l_l_wait_38_0 = l_wait_38
		local l_l_KJThrow_0_0 = l_KJThrow_0
		local l_v23804_0 = v23804

		local function SpinEvent()
			local l_Position_101 = {}
			local spinAngle = -5

			-- BV2: spiraling deceleration from speed 40, with side drift, lives until Toss fires
			local bv2 = Instance.new("BodyVelocity")
			bv2.Name = "SpiralingStormVelocity"
			bv2.MaxForce = Vector3.new(40000, 0, 40000)
			bv2.Velocity = Vector3.new(0, 0, 0)
			bv2.Parent = l_l_PrimaryPart_103_0

			local bv2Active = true
			local function stopBV2()
				if bv2Active then
					bv2Active = false
					if bv2 and bv2.Parent then
						bv2:Destroy()
					end
				end
			end
			task.spawn(function()
				local speed   = 40
				local side    = 100
				local fallout = 0.9
				local sideFO  = 0.9
				local endSpeed = -5

				while bv2Active do
					local cf    = l_l_PrimaryPart_103_0.CFrame
					local fwd   = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
					local right = Vector3.new(cf.LookVector.Z, 0, -cf.LookVector.X)

					if fwd.Magnitude > 0 then
						bv2.Velocity = fwd.Unit * speed + right.Unit * side
					end

					speed = speed * fallout
					side  = side  * sideFO

					if speed <= endSpeed then
						stopBV2()
						break
					end

					task.wait(0.1)
				end
			end)
			task.delay(15, stopBV2)

			task.spawn(function()
				local v23820 = tick()
				while tick() - v23820 < 4 do
					for _, v23822 in pairs(l_Position_101) do
						v23822.PrimaryPart.CFrame = v23822.PrimaryPart.CFrame * CFrame.Angles(0, 0, math.rad(spinAngle))
						v23822.PrimaryPart.Position = l_l_PrimaryPart_103_0.CFrame * CFrame.new(0, 0, -1).Position - Vector3.new(0, l_l_PrimaryPart_103_0.Size.Y * 1.5, 0)
					end
					l_l_wait_38_0(0.01)
				end
			end)

			task.spawn(function()
				local v23823 = CloneAndPlaceFX({
					FX = l_l_KJThrow_0_0.Spinning,
					Anchor = l_l_PrimaryPart_103_0.CFrame * CFrame.new(0, -l_l_PrimaryPart_103_0.Size.Y * 1.5, 0) * CFrame.Angles(1.5707963267948966, 0, 0),
					Maid = l_v23804_0._maid
				})
				Debris:AddItem(v23823, 5)
				toggleFX({ FX = v23823, On = true })
				v23823:ScaleTo(0.7)
				table.insert(l_Position_101, v23823)

				for v23824 = 1, 12 do
					local v23825 = v23824 * 0.01
					local v23826 = l_l_KJThrow_0_0.TestWind2:Clone()
					Debris:AddItem(v23826, 5)
					v23826:ScaleTo(0.45 + v23825)
					task.spawn(TweenModel, {
						Model = v23826,
						Anchor = l_l_PrimaryPart_103_0.CFrame * CFrame.new(0, -1, -1) * CFrame.Angles(0, -0.7853981633974483, 1.5707963267948966),
						Info = TweenInfo.new(0.4, Enum.EasingStyle.Sine)
					})

					if v23824 > 2 then
						local v23827 = l_l_KJThrow_0_0.TEst:Clone()
						Debris:AddItem(v23827, 5)
						v23827:ScaleTo(1 + v23825)
						task.spawn(TweenModel, {
							Model = v23827,
							Anchor = l_l_PrimaryPart_103_0.CFrame * CFrame.new(0, -1, -1) * CFrame.Angles(0, -0.7853981633974483, 0),
							Info = TweenInfo.new(0.8, Enum.EasingStyle.Sine)
						})
					end
					l_l_wait_38_0(0.1)
				end

				local v23873 = CloneAndPlaceFX({
					FX = l_l_KJThrow_0_0.Toss,
					Anchor = l_l_PrimaryPart_103_0.CFrame * CFrame.new(0, 0, -7) * CFrame.Angles(0, 0, 0),
					Maid = l_v23804_0._maid
				})
				Debris:AddItem(v23873, 5)
				handleFX(v23873)
				v23873:ScaleTo(1.3)
				spinAngle = -0.5
				stopBV2()  -- spin ends, throw happens — kill BV2
				toggleFX({ FX = v23823, On = false })

				local upwave2 = l_l_KJThrow_0_0.Upwave2:Clone()
				Debris:AddItem(upwave2, 5)
				upwave2:ScaleTo(0.7)
				task.spawn(TweenModel, {
