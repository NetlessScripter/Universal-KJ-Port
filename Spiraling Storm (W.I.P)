					if not table.find(v1036, v1044) then
						table.insert(v1036, v1044)
					end
					return v1044
				end,
				GetChildren = function(_)
					return rawget(v1038, v1042):GetChildren()
				end,
				GetAttribute = function(_, v1047)
					return rawget(v1038, v1042):GetAttribute(v1047)
				end
			}
		end
	})
	local v1049 = { _maid = {} }
	local function give(_, v1051)
		if not table.find(v1036, v1051) then
			table.insert(v1036, v1051)
		end
		return v1051
	end
	v1049._maid.give = give
	v1049._maid.giveTask = give
	local function cleanup()
		if v1048 and v1049 then
			table.clear(v1048)
			table.clear(v1049)
		end
		if v1038 then
			table.clear(v1038)
			v1038 = nil
		end
		v1049 = nil
		v1048 = nil
		if v1036 then
			for v1055, v1056 in pairs(v1036) do
				if typeof(v1056) == "RBXScriptConnection" then
					v1056:Disconnect()
				elseif typeof(v1056) == "Instance" then
					v1056:Destroy()
				end
				v1036[v1055] = nil
			end
			table.clear(v1036)
		end
		v1036 = nil
	end
	local timeout = 10
	if v1037 ~= nil and typeof(v1037) == "number" then
		timeout = v1037
	end
	task.delay(timeout, cleanup)
	return v1048, v1049, cleanup
end

