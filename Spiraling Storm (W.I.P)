-- CloneAndPlaceFX (v1000)
local function CloneAndPlaceFX(v997)
	local l_FX = v997.FX
	local l_Anchor = v997.Anchor
	l_FX = l_FX:Clone()
	if l_FX:IsA("Model") then
		l_FX:PivotTo(l_Anchor)
	elseif l_FX:IsA("BasePart") then
		l_FX.CFrame = l_Anchor
	end
	if l_FX:IsA("Attachment") then
		l_FX.Parent = l_Anchor
	else
		l_FX.Parent = workspace.Thrown
	end
	Debris:AddItem(l_FX, 30)
	return l_FX
end

-- handleFX (v1014)
local function handleFX(v1001, v1002, v1003)
	for _, v1005 in pairs(v1001:GetDescendants()) do
		if v1005:IsA("ParticleEmitter") then
			local attrs = v1005:GetAttributes()
			local emitDelay = attrs.EmitDelay
			if emitDelay then
				local attrsCopy = attrs
				task.delay(emitDelay, function()
					v1005:Emit(attrsCopy.EmitCount)
				end)
			else
				v1005:Emit(attrs.EmitCount)
			end
			if attrs.EmitDuration then
				v1005.Enabled = true
				task.delay(attrs.EmitDuration, function()
					v1005.Enabled = false
				end)
			end
		end
		if v1005:IsA("Beam") then
			local attrs = v1005:GetAttributes()
			local duration = attrs.Duration
			local tweenTime = (v1003 and v1003.TweenTime) or 0.5
			TweenService:Create(v1005, TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
				Width1 = attrs.Width1,
				Width0 = attrs.Width0
			}):Play()
			if duration then
				task.delay(duration, function()
					TweenService:Create(v1005, TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
						Width1 = 0,
						Width0 = 0
					}):Play()
				end)
			end
		end
	end
	if v1002 then
		Debris:AddItem(v1001, v1002)
	end
end

-- toggleFX (v1021)
local function toggleFX(v1015)
	local l_FX = v1015.FX
	if v1015.On then
		for _, v in pairs(l_FX:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v.Enabled = true
			end
		end
	else
		for _, v in pairs(l_FX:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v.Enabled = false
			end
		end
	end
end

-- scaleParticleLifetime (v989)
local function scaleParticleLifetime(v984)
	local l_FX = v984.FX
	local l_Scale = v984.Scale
	for _, v in pairs(l_FX:GetDescendants()) do
		if v:IsA("ParticleEmitter") then
			v.Lifetime = NumberRange.new(v.Lifetime.Min * l_Scale, v.Lifetime.Max * l_Scale)
		end
	end
end

