local function TweenModel(v)
	local l_Model = v.Model
	local tweenInfo = v.Info or TweenInfo.new(1, Enum.EasingStyle.Sine)
	local l_Start = l_Model:FindFirstChild("Start")
	local l_End = l_Model:FindFirstChild("End")
	local l_Stay = v.Stay
	local l_Anchor = v.Anchor
	local endT = v.EndT or 1
	local l_Del = v.Del
	local l_Skip = v.Skip

	if not (l_Start and l_End) then
		warn("NO START OR END")
		return
	end

	l_Model.PrimaryPart = l_Start
	if not l_Skip then
		for _, part in pairs(l_Model:GetChildren()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
				part.Anchored = true
			end
		end
	end
	if l_Anchor then
		l_Model:SetPrimaryPartCFrame(l_Anchor)
	end
	if v.T then
		l_Start.Transparency = v.T
	end
	l_End.Transparency = 1
	l_Model.Parent = workspace.Thrown

	local l_Decal_Start = l_Start:FindFirstChildOfClass("Decal")
	local l_SpecialMesh_Start = l_Start:FindFirstChildOfClass("SpecialMesh")
	local l_SpecialMesh_End = l_End:FindFirstChildOfClass("SpecialMesh")
	local l_Decal_End = l_End:FindFirstChildOfClass("Decal")

	if l_Decal_End and not l_Skip then
		l_Decal_End.Transparency = 1
	end

	local tween = nil

	if l_Del then
		TweenService:Create(l_Start, tweenInfo, {
			Size = l_End.Size,
			CFrame = l_End.CFrame
		}):Play()
		task.delay(l_Del, function()
			tween = TweenService:Create(l_Start, tweenInfo, { Transparency = endT })
			tween:Play()
			if l_Decal_Start then
				for _, d in pairs(l_Start:GetChildren()) do
					if d:IsA("Decal") then
						TweenService:Create(d, tweenInfo, { Transparency = endT }):Play()
					end
				end
			end
			if l_SpecialMesh_Start then
				tween = TweenService:Create(l_SpecialMesh_Start, tweenInfo, { Scale = l_SpecialMesh_End.Scale }):Play()
			end
		end)
	else
		if l_SpecialMesh_Start then
			TweenService:Create(l_SpecialMesh_Start, tweenInfo, { Scale = l_SpecialMesh_End.Scale }):Play()
		end
		if l_Decal_Start then
			for _, d in pairs(l_Start:GetChildren()) do
				if d:IsA("Decal") then
					TweenService:Create(d, tweenInfo, { Transparency = endT }):Play()
				end
			end
			tween = TweenService:Create(l_Start, tweenInfo, {
				Size = l_End.Size,
				CFrame = l_End.CFrame
			})
			tween:Play()
		else
			tween = TweenService:Create(l_Start, tweenInfo, {
				Size = l_End.Size,
				Transparency = endT,
				CFrame = l_End.CFrame
			})
			tween:Play()
		end
	end

	if not l_Stay then
		if l_Del then
			task.wait(l_Del + 0.1)
		end
		if tween then
			tween.Completed:Connect(function()
				l_Model:Destroy()
			end)
		end
	end
end

