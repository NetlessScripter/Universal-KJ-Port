					Info = TweenInfo.new(0.3, Enum.EasingStyle.Sine)
				})
			end)
		end

		if l_Spin_0 then
			task.delay(0.3, SpinEvent)
		end
	end

	-- FirstEvent always fires
	do
		local l_l_KJThrow_0_1 = l_KJThrow_0
		local l_v23804_1 = v23804
		local l_l_PrimaryPart_103_1 = l_PrimaryPart_103
		local l_l_wait_38_1 = l_wait_38

		local function FirstEvent()
			-- BV1: accelerates from speed 15 → 50 (capped) over 0.5s with spiral side drift
			task.spawn(function()
				local bv1 = Instance.new("BodyVelocity")
