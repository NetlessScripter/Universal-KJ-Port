-- FIVE SEASON CAMERA
-- Launches an orbital camera that follows the character upward, then snaps
-- back to the char's landing position when the HurryUPFS signal arrives or
-- after 5 seconds timeout.
-------------------------------------------------------------------------------
local function FiveSeasonCamera(data)
    local char = data.Char
    -- Save the character's CFrame so we can restore it instead of using a BodyPosition
    local savedCF = char.HumanoidRootPart.CFrame

    -- Signal folder so the Startup camera knows we entered this phase
    local locFolder  = Instance.new("Folder")
    locFolder.Name   = "locatingtarg"
    locFolder.Parent = char
    Debris:AddItem(locFolder, 1)

    -- Invisible physics part the camera chases
    local trackPart            = Instance.new("Part")
    trackPart.Transparency     = 1
    trackPart.CanCollide        = false
    trackPart.CanTouch          = false
    trackPart.CanQuery          = false
    trackPart.Size              = Vector3.new(1, 1, 1)  -- FIX [1]: was (1,1,1,0)

    local bv          = Instance.new("BodyVelocity")
    bv.MaxForce        = Vector3.new(100000, 100000, 100000)  -- FIX [1]: was (100000,100000,100000,0)
    bv.Velocity        = Vector3.new(0, 0, 0)                 -- FIX [1]: was (0,0,0,0)
    bv.Parent          = trackPart

    local cam          = workspace.CurrentCamera
    trackPart.CFrame   = cam.CFrame
    -- Flatten look vector to horizontal plane
    trackPart.CFrame   = CFrame.lookAlong(
        trackPart.Position,
        trackPart.CFrame.LookVector * Vector3.new(1, 0, 1)  -- FIX [1]: was (1,0,1,0)
    )
    trackPart.Parent   = workspace.Thrown
    cam.CameraType     = Enum.CameraType.Scriptable

    -- Tween values that drive the tracking part movement
    local pitchVal = Instance.new("NumberValue"); pitchVal.Value = 0
    local speedVal = Instance.new("NumberValue"); speedVal.Value = 125
    local upVal    = Instance.new("NumberValue"); upVal.Value    = 100

    TweenService:Create(upVal,    TweenInfo.new(1,  Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Value = 0   }):Play()
    TweenService:Create(speedVal, TweenInfo.new(10, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Value = 0   }):Play()
    TweenService:Create(pitchVal, TweenInfo.new(1,  Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Value = -90 }):Play()
    TweenService:Create(cam,      TweenInfo.new(1,  Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { FieldOfView = 40 }):Play()

    -- Movement loop: drives the trackPart with character move direction + upward float
    local lastTick = tick()
    local loopStop = loop(function()
        local now = tick()
        local dt  = now - lastTick
        lastTick  = now
        cam.CameraType = Enum.CameraType.Scriptable
        bv.Velocity = bv.Velocity:Lerp(
            char.Humanoid.MoveDirection * speedVal.Value + Vector3.new(0, upVal.Value, 0),
            1 - (5e-7 ^ dt)
        )
    end, 90)

    -- Render stepped: camera follows trackPart with pitch offset
    local renderConn = RunService.RenderStepped:Connect(function(dt)
        cam.CFrame = cam.CFrame:Lerp(
            trackPart.CFrame * CFrame.Angles(math.rad(pitchVal.Value), 0, 0),
            1 - (5e-5 ^ dt)
        )
    end)

    -- Temporarily disable shadow casting for a clean cinematic look
    local shadowCache = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            shadowCache[part] = part.CastShadow
            part.CastShadow   = false
        end
    end

    -- Wait for ATK signal or timeout
    local waitStart = tick()
    repeat task.wait()
    until tick() - waitStart > 5 or char:FindFirstChild("HurryUPFS")

    -- Restore shadows after a short delay
    task.delay(0.75, function()
        for part, val in pairs(shadowCache) do
            part.CastShadow = val
        end
    end)

    -- Teleport character to where the trackPart ended up
    local landingCF = trackPart.CFrame
    char:PivotTo(landingCF)
    renderConn:Disconnect()
    loopStop()

    pitchVal:Destroy()
    speedVal:Destroy()
    bv:Destroy()
    trackPart:Destroy()

    -- Wait 0.3s then anchor — unanchor happens after explosion in FiveSeasonAtk
    task.wait(0.3)
    char.HumanoidRootPart.Anchored = true
end

-------------------------------------------------------------------------------
-- FIVE SEASON ATK
-- Plays the attack camera cutscene, fist model animation, explosion, and
-- all impact frame / color-correction effects.
-------------------------------------------------------------------------------
local function FiveSeasonAtk(data)
    local char        = data.Char
    local rootPart    = char.HumanoidRootPart
    local primaryPart = char.HumanoidRootPart
    local localChar   = LocalPlayer.Character
    local FX          = FXStorage
    local Thrown      = workspace.Thrown
    local TweenSvc    = TweenService

    -- Body velocity keeps the character grounded during the cutscene
    local bv        = Instance.new("BodyVelocity")
    bv.MaxForce      = Vector3.new(400000000, 400000000, 400000000)
    bv.Velocity      = Vector3.new(0, 0, 0)
    bv.Parent        = primaryPart

    local renderConn = nil

    -- ── Camera cutscene (local player only) ──────────────────────────────────
    if localChar == char then
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Scriptable
        StarterGui:SetCore("ResetButtonCallback", false)
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)

        local hrp = char:WaitForChild("HumanoidRootPart")
        local storedRot = CFrame.new(Vector3.zero, hrp.CFrame.LookVector)

        local FSATKData
        if not _G.FSATK then
            FSATKData = loadstring(game:HttpGet("https://raw.githubusercontent.com/NetlessScripter/BEST-TSB-MOVESET/refs/heads/main/Yes"))()
            _G.FSATK = FSATKData
        else
            FSATKData = _G.FSATK
        end

        local frameCount  = 0
        local startTick2  = tick()
        local lastCF      = nil
        local cutDone     = false

        function EndCutscene()
            if renderConn then renderConn:Disconnect() end
            cutDone = true
            StarterGui:SetCore("ResetButtonCallback", true)
            StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
            cam.CameraType = Enum.CameraType.Custom
            TweenSvc:Create(cam, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { FieldOfView = 70 }):Play()
        end

        renderConn = RunService.RenderStepped:Connect(function(dt)
            local steps = dt * 60
            frameCount += steps
            local idx = tonumber(math.ceil(frameCount))
            if idx >= 198 and idx <= 200 then idx = 197 end
            local data = FSATKData[idx]

            if localChar.Parent and data and not cutDone then
                if cam.CameraType ~= Enum.CameraType.Scriptable then
                    cam.CameraType = Enum.CameraType.Scriptable
                end

                if tick() - startTick2 > 0.7 then
                    cam.FieldOfView = data.fov
                else
                    cam.FieldOfView += (data.fov - cam.FieldOfView) * (1 - 0.009 ^ dt)
                end

                local base   = CFrame.new(hrp.Position) * storedRot.Rotation
                local target = base * data.cframe
                local jumped = lastCF and (lastCF.Position - target.Position).Magnitude >= 10
                lastCF = target

                if jumped then
                    cam.CFrame = target
                elseif tick() - startTick2 > 0.7 then
                    cam.CFrame = base * data.cframe
                else
                    cam.CFrame = cam.CFrame:Lerp(base * data.cframe, 1 - 9e-5 ^ dt)
                end
            end
        end)
    end

    -- ── FXUi (local only) ────────────────────────────────────────────────────
    local fxUi        = nil
    local vignetteImg = nil
    local fiveSeasons = nil
    local fsDots      = nil

    if localChar == char then
        fxUi        = FX.FXUi:Clone()
        vignetteImg = fxUi.Vignette
        fiveSeasons = fxUi.FiveSeasons
        fsDots      = fxUi.FiveSeasonsDots
        fsDots.ImageTransparency = 1
    end

    -- ── FinalArmFXMirrored at 1.25 s ─────────────────────────────────────────
    task.delay(1.25, function()
        local armFXMirror  = FX.CharFX.FinalArmFXMirrored:Clone()
        armFXMirror.Parent = char["Left Arm"]
        task.wait(0.75)
        for _, emitter in ipairs(armFXMirror:GetDescendants()) do
            if emitter:IsA("ParticleEmitter") then
                emitter.Enabled = false
            end
        end
        task.wait(1)
        armFXMirror:Destroy()
    end)

    -- ── Vignette at 1.35 s ───────────────────────────────────────────────────
    task.delay(1.35, function()
        if LocalPlayer.Character ~= char then return end
        fxUi.Parent = LocalPlayer.PlayerGui
        TweenSvc:Create(fxUi.Vignette,
            TweenInfo.new(0.55, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
            { ImageTransparency = 0 }
        ):Play()
    end)

    -- ── TP particle at 1.05 s ────────────────────────────────────────────────
    task.delay(1.05, function()
        local tpFX  = FX.CharFX.TP:Clone()
        tpFX.Parent = char.Torso
        for _, emitter in ipairs(tpFX:GetDescendants()) do
            if emitter:IsA("ParticleEmitter") then
                emitter:Emit(emitter:GetAttribute("EmitCount"))
            end
        end
        task.wait(0.5)
        tpFX:Destroy()
    end)

    -- ── Finale sequence at 1.983 s ───────────────────────────────────────────
    task.delay(1.983, function()
        if fxUi then fxUi.Vignette.Visible = false end

        Sound6D("rbxassetid://18461821277", 3)

        -- Kill tagged sounds from startup
        for _, tagged in ipairs(CollectionService:GetTagged("kjfs" .. char.Name)) do
            tagged:Destroy()
        end

        -- FiveSeasons / FiveSeasonsDots flash
        if fxUi then
            fiveSeasons.Visible           = true
            fiveSeasons.ImageTransparency = 1
            fiveSeasons.ImageColor3       = Color3.fromRGB(0, 0, 0)
            TweenSvc:Create(fiveSeasons,
                TweenInfo.new(0.005, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
                { ImageTransparency = 0 }
            ):Play()
            TweenSvc:Create(fiveSeasons,
                TweenInfo.new(0.25, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
                { ImageColor3 = Color3.fromRGB(255, 255, 255) }
            ):Play()
            fsDots.Visible = true
            TweenSvc:Create(fsDots,
                TweenInfo.new(1.4, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
                { ImageTransparency = 0 }
            ):Play()
        end

        task.wait(1.7)

        -- Grayscale color correction
        local grayScale = nil
        if fxUi then
            fiveSeasons.Visible = false
            fsDots.Visible      = false
            grayScale           = FX.GrayScale:Clone()
            grayScale.Parent    = game.Lighting
            TweenSvc:Create(grayScale,
                TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
                { Brightness = 0, Contrast = 0, Saturation = 0 }
            ):Play()
        end

        -- Fists model (the iconic spinning fists that fly forward)
        local fistsModel = FX.FistsModelMirrored:Clone()
        fistsModel:SetPrimaryPartCFrame(char.HumanoidRootPart.CFrame)

        -- ── Smoke mesh billows ────────────────────────────────────────────────
        local function SmokeTween()
            local dur       = Random.new():NextNumber(0.5, 2.75)
            local smokeMesh = FX.FinalExplosion.SmokeMesh:Clone()
            local scale     = smokeMesh:GetScale()
            smokeMesh:ScaleTo(Random.new():NextNumber(scale - 0.2, scale + 1))
            local angles    = Vector3.new(math.random(0,360), math.random(0,360), math.random(0,360))
            smokeMesh:SetPrimaryPartCFrame(
                CFrame.new(smokeMesh.PrimaryPart.Position)
                * CFrame.Angles(math.rad(angles.X), math.rad(angles.Y), math.rad(angles.Z))
            )
            local startP = smokeMesh.Start
            local endP   = smokeMesh.End
            local mesh   = startP:Clone()
            mesh.Transparency = 0.92
            mesh.Name         = "ClonedMesh"
            mesh.Parent       = workspace.Thrown
            TweenSvc:Create(mesh,
                TweenInfo.new(dur, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
                { Size = endP.Size, CFrame = endP.CFrame }
            ):Play()
            TweenSvc:Create(mesh,
                TweenInfo.new(dur, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
                { Transparency = 1 }
            ):Play()
            TweenSvc:Create(mesh,
                TweenInfo.new(dur / 4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
                { Color = Color3.fromRGB(149, 149, 149) }
            ):Play()
            task.wait(3)
            mesh:Destroy()
            smokeMesh:Destroy()
        end

        -- ── Wind ring pulses ──────────────────────────────────────────────────
        local function WindRing()
            task.spawn(function()
                local dur      = Random.new():NextNumber(0.3, 1.75)
                local windMesh = FX.FinalExplosion.WindRing:Clone()
                local scale    = windMesh:GetScale()
                windMesh:ScaleTo(Random.new():NextNumber(scale - 0.65, scale + 0.65))
                local angle    = math.random(0, 360)
                windMesh:SetPrimaryPartCFrame(
                    windMesh.PrimaryPart.CFrame * CFrame.Angles(0, math.rad(angle), 0)
                )
                local startP = windMesh.Start
                local endP   = windMesh.End
                local mesh   = startP:Clone()
                mesh.Decal.Transparency = 0.85
                mesh.Name               = "ClonedMesh"
                mesh.Parent             = workspace.Thrown
                TweenSvc:Create(mesh,
                    TweenInfo.new(dur, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                    { Size = endP.Size, CFrame = endP.CFrame }
                ):Play()
                TweenSvc:Create(mesh.Mesh,
                    TweenInfo.new(dur, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
                    { Scale = endP.Mesh.Scale }
                ):Play()
                TweenSvc:Create(mesh.Decal,
                    TweenInfo.new(dur, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut),
                    { Transparency = 1 }
                ):Play()
                task.wait(dur)
                mesh:Destroy()
                windMesh:Destroy()
            end)
        end

        task.delay(4.5, function()
            fistsModel:Destroy()
        end)

        if LocalPlayer.Character ~= char then task.wait(1.45) end

        fistsModel.Parent = Thrown
        Sound6D("rbxassetid://18462018744", 10)

        local primaryFist = fistsModel.Primary

        -- Ring 1 & 2 expand tweens
        task.delay(0.065, function()
            fistsModel.Ring1.Start.Transparency = 0.6
            TweenSvc:Create(fistsModel.Ring1.Start,
                TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = fistsModel.Ring1.End.Size }
            ):Play()
            TweenSvc:Create(fistsModel.Ring1.Start,
                TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { CFrame = fistsModel.Ring1.End.CFrame }
            ):Play()
            TweenSvc:Create(fistsModel.Ring1.Start,
                TweenInfo.new(0.55, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
                { Transparency = 1 }
            ):Play()
            task.wait(0.15)
            fistsModel.Ring2.Start.Transparency = 0.6
            TweenSvc:Create(fistsModel.Ring2.Start,
                TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = fistsModel.Ring2.End.Size }
            ):Play()
            TweenSvc:Create(fistsModel.Ring2.Start,
                TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { CFrame = fistsModel.Ring2.End.CFrame }
            ):Play()
            TweenSvc:Create(fistsModel.Ring2.Start,
                TweenInfo.new(0.4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
                { Transparency = 1 }
            ):Play()
        end)

        -- Particle slow-motion on primary fist
        for _, emitter in ipairs(primaryFist:GetDescendants()) do
            if emitter:IsA("ParticleEmitter") then
                task.spawn(function()
                    TweenSvc:Create(emitter,
                        TweenInfo.new(1.92, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
                        { TimeScale = 0.1 }
                    ):Play()
                    task.wait(1.92)
                    emitter.TimeScale = 1
                    emitter.Enabled   = false
                end)
            end
        end

        -- Fist parts fly forward
        for _, part in ipairs(fistsModel.Fists:GetDescendants()) do
            if part:IsA("MeshPart") or part:IsA("BasePart") then
                task.spawn(function()
                    -- FIX [3]: was NextNumber(1.92, 1.88) — min > max
                    local dur = Random.new():NextNumber(1.88, 1.92)
                    TweenSvc:Create(part,
                        TweenInfo.new(dur, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
                        { Position = part.Position + primaryFist.CFrame.LookVector * 28 }
                    ):Play()
                    task.wait(dur)
                    -- FIX [4]: was NextNumber(0.23, 0.2) — min > max
                    TweenSvc:Create(part,
                        TweenInfo.new(Random.new():NextNumber(0.2, 0.23), Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
                        { Position = part.Position + primaryFist.CFrame.LookVector * 800 }
                    ):Play()
                end)
            end
        end

        -- Clone main mesh for dissolve flash
        for _, part in ipairs(fistsModel.Fists:GetDescendants()) do
            if part:IsA("MeshPart") and part.Name == "Main" then
                local clonedMesh  = part:Clone()
                clonedMesh.Parent = Thrown
                clonedMesh.Color  = Color3.fromRGB(66, 4, 4)
                local dur         = Random.new():NextNumber(0.45, 0.55)
                TweenSvc:Create(clonedMesh,
                    TweenInfo.new(dur, Enum.EasingStyle.Cubic, Enum.EasingDirection.InOut),
                    { Transparency = 1, Size = part.Size * 1.085 }
                ):Play()
                task.delay(1, function() clonedMesh:Destroy() end)
            end
        end

        task.wait(1.92)
        if grayScale then grayScale:Destroy() end

        -- Color-correction triple flash
        local ccRed, ccWhite, ccBlack
        if fxUi then
            ccRed   = FX.FistsCC.FSRed:Clone();   ccRed.Parent   = game.Lighting
            ccWhite = FX.FistsCC.FSWhite:Clone();  ccWhite.Parent = game.Lighting
            ccBlack = FX.FistsCC.FSBlack:Clone();  ccBlack.Parent = game.Lighting
        end
        task.wait(0.008)
        if fxUi and LocalPlayer.Character == char then ccWhite.Enabled = true end
        task.wait(0.02)
        if fxUi and LocalPlayer.Character == char then
            ccWhite.Enabled = false
            ccBlack.Enabled = true
        end
        task.wait(0.02)
        if fxUi then
            ccBlack.Enabled = false
            ccRed:Destroy(); ccWhite:Destroy(); ccBlack:Destroy()
        end

        -- White screen flash
        if fxUi and LocalPlayer.Character == char then
            fxUi.White.Visible           = true
            fxUi.White.ImageTransparency = 0
            TweenSvc:Create(fxUi.White,
                TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                { ImageTransparency = 1 }
            ):Play()
        end

        -- Impact frame animation
        local frameList  = nil
        local frameIdx   = 1
        local prevFrame  = nil

        if fxUi then
            Sound6D("rbxassetid://18462312002", 7)
            frameList = fxUi.ImpactFrames:GetChildren()
            table.sort(frameList, function(a, b)
                local nA, nB = tonumber(a.Name), tonumber(b.Name)
                if nA and nB then return nA < nB end
                return tostring(a.Name) < tostring(b.Name)
            end)
        else
            frameList = {}
            for i = 1, 40 do table.insert(frameList, i) end
        end

        if LocalPlayer.Character == char then
            loop(function(stop)
                local frameImg = frameList[frameIdx]
                if frameImg then
                    if typeof(frameImg) == "Instance" then
                        frameImg.Size     = UDim2.new(1, 0, 1, 0)
                        frameImg.Position = UDim2.new(0.5, 0, 0.5, 0)
                    end
                else
                    cutDone = true
                    stop()
                    task.defer(EndCutscene)

                    -- Explosion fires right as impact frames finish
                    task.spawn(function()
                        local _, hitPos   = Raycast({ orig = rootPart.Position, dir = Vector3.new(0, -1000, 0) })
                        local explosionPos = hitPos
                            and hitPos + Vector3.new(0, 0.2, 0)
                            or (rootPart.CFrame * CFrame.new(
                                    5.24520874e-5, -106.229225, -29.8572197,
                                    0.906307757, 0, -0.42261833,
                                    0, 1, 0,
                                    0.42261833, 0, 0.906307757
                               )).Position

                        local explosion = FX.FinalExplosion:Clone()
                        explosion:ScaleTo(1.25)
                        explosion.Parent = workspace.Thrown
                        explosion:PivotTo(CFrame.new(explosionPos))
                        explosion.Particles.Enabled.EnabledP.Enabled = true

                        -- Unanchor 2 seconds after explosion
                        task.delay(2, function()
                            char.HumanoidRootPart.Anchored = false
                        end)

                        Sound6D("rbxassetid://18462330981", 10)

                        task.delay(10, function()
                            explosion.Particles.Enabled.EnabledP.Enabled = false
                            task.wait(10)
                            explosion:Destroy()
                        end)

                        for _, emitter in ipairs(explosion.Particles:GetDescendants()) do
                            if emitter:IsA("ParticleEmitter") then
                                emitter:Emit(emitter:GetAttribute("EmitCount"))
                                task.spawn(function()
                                    local ts = emitter.TimeScale
                                    emitter.TimeScale = 0.1
                                    task.wait(0.11)
                                    emitter.TimeScale = ts
                                end)
                            end
                        end

                        -- Blue impact frame CC
                        if fxUi then
                            local impactCC = FX.ImpactFrameBlue:Clone()
                            if LocalPlayer.Character == char then
                                impactCC.Parent  = game.Lighting
                                impactCC.Enabled = true
                            end
                            task.wait(0.03)
                            impactCC.Enabled = false
                        end

                        -- Smoke billows + wind rings
                        task.spawn(function()
                            task.spawn(SmokeTween)
                            task.spawn(SmokeTween)
                            task.spawn(SmokeTween)
                            task.spawn(SmokeTween)
                            task.spawn(SmokeTween)
                            for _ = 1, 5 do
                                WindRing()
                                task.wait(0.04)
                            end
                        end)
                    end)
                end
                if prevFrame and typeof(prevFrame) == "Instance" then
                    prevFrame:Destroy()
                end
                prevFrame = frameImg
                frameIdx  = frameIdx + 1
            end, 26, true)

            LocalPlayer.CameraMinZoomDistance = 85
            TweenSvc:Create(LocalPlayer,
                TweenInfo.new(2, Enum.EasingStyle.Sine),
                { CameraMinZoomDistance = 0.05 }
            ):Play()

            -- Brief downward camera look for impact emphasis
            local punchTick = tick()
            local punchCam  = workspace.CurrentCamera
            local punchConn = nil
            punchConn = RunService.Heartbeat:Connect(function()
                if tick() - punchTick > 0.15 then
                    punchConn:Disconnect()
                else
                    punchCam.CFrame = CFrame.new(
                        punchCam.CFrame.Position,
                        (rootPart.CFrame * CFrame.new(0, -40, 0)).Position
                    )
                end
            end)
        else
            task.wait(0.075)
        end

        Debris:AddItem(bv, 2)
    end)
end

