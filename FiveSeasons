-- ─── shared.loop replacement ─────────────────────────────────────────────────
-- Runs callback at targetFps. If passStop is true, passes a stop() fn as arg.
-- Returns a stop function.
local function loop(callback, targetFps, passStop)
    local stopped = false
    local interval = 1 / (targetFps or 60)
    local stopFn = function() stopped = true end
    task.spawn(function()
        while not stopped do
            if passStop then
                callback(stopFn)
            else
                callback()
            end
            task.wait(interval)
        end
    end)
    return stopFn
end

