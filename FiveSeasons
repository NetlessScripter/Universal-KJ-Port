-- FIVE SEASON STARTUP
-- Handles the full startup sequence: sound fade-in, heat particles, jump ring
-- mesh, beam FX, hand fire, shadow decals, arm burst, and eye emit.
-------------------------------------------------------------------------------
local function FiveSeasonStartup(data)
    local char     = data.Char
    local TweenSvc = TweenService
    local FX       = FXStorage
    local Thrown   = workspace.Thrown

    -- Startup ambient sound (tagged so ATK can clean it up later)
    local startSound = Instance.new("Sound")
    startSound.SoundId = "rbxassetid://18460952794"
    startSound.Volume  = 0
    CollectionService:AddTag(startSound, "kjfs" .. char.Name)

    -- Camera cutscene only plays for the local player's character
    if char == LocalPlayer.Character then
        startSound.Parent = workspace

        task.delay(0.9, function()
            local Folder = Instance.new("Folder")
            Folder.Name = "NoRotate"
            Folder.Parent = char

            local FSSUData
            if not _G.FSSU then
                FSSUData = loadstring(game:HttpGet("https://raw.githubusercontent.com/NetlessScripter/BEST-TSB-MOVESET/refs/heads/main/Yup"))()
                _G.FSSU = FSSUData
            else
                FSSUData = _G.FSSU
            end

            local Camera = workspace.CurrentCamera
            Camera.CameraType = Enum.CameraType.Scriptable

            local Root = char:FindFirstChild("HumanoidRootPart")
            if not Root then return end

            local Start = tick()
            local SavedCFrame
            local LastCFrame
            local FrameCount = 0
            local Connection

            Connection = RunService.RenderStepped:Connect(function(dt)
                local Steps = dt * 60
                FrameCount += Steps
                local Index = math.ceil(FrameCount)
                if Index >= 340 and not SavedCFrame then
                    SavedCFrame = Root.CFrame
                end

                local Data = FSSUData[Index]
                if char.Parent and Data and not char:FindFirstChild("locatingtarg") then
                    if Camera.CameraType ~= Enum.CameraType.Scriptable then
                        Camera.CameraType = Enum.CameraType.Scriptable
                    end

                    if Data and not SavedCFrame then
                        local Alpha = tick() - Start > 1 and (1 - 9e-25 ^ dt) or (1 - 9e-7 ^ dt)
                        Camera.FieldOfView += (Data.fov - Camera.FieldOfView) * Alpha
                    end

                    if Data then
                        local Target = (SavedCFrame or Root.CFrame) * Data.cframe
                        local Jumped = LastCFrame and (LastCFrame.Position - Target.Position).Magnitude >= 10
                        LastCFrame = Target
                        local Alpha = tick() - Start > 1 and (1 - 9e-25 ^ dt) or (1 - 9e-7 ^ dt)
                        Camera.CFrame = Jumped and Target or Camera.CFrame:Lerp(Target, Alpha)
                    end
                else
                    Folder:Destroy()
                    Connection:Disconnect()
                    Camera.CameraType = Enum.CameraType.Custom
                end
            end)
        end)

        Sound6D("rbxassetid://18460952794", 2)
    end

    -- ── HeatUp particle burst (visible to everyone) ──────────────────────────
    task.spawn(function()
        local heatUp  = FX.CharFX.HeatUp:Clone()
