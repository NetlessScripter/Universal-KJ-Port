-- ─── Raycast helper (replaces the v717 upvalue from the main script) ─────────
-- FIX [7]: v717 was an upvalue from the outer interpreter closure.
--          We recreate it here as a standalone helper.
local _RayParams = RaycastParams.new()
_RayParams.FilterDescendantsInstances = { workspace.Thrown, workspace.Live }
_RayParams.FilterType                 = Enum.RaycastFilterType.Exclude

local function Raycast(data)
    local result = workspace:Raycast(data.orig, data.dir, _RayParams)
    if result then
        return result.Instance, result.Position
    end
    return nil, nil
end

