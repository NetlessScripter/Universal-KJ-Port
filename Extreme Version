local tlist = {}

local noTrailParts = {
	["Torso"] = true, ["UpperTorso"] = true, ["LowerTorso"] = true,
	["HumanoidRootPart"] = true, ["Head"] = true
}

for _,v in pairs(CharacterRef:GetChildren()) do
	if v:IsA("BasePart") and not noTrailParts[v.Name] then
		local a0 = Instance.new("Attachment",v)
		local a1 = Instance.new("Attachment",v)

		-- DCEU-style: a1 fans outward from the character instead of trailing behind.
		-- Origin (a0) sits at the part center; endpoint (a1) is pushed far out
		-- horizontally so the trail slices AWAY from the body to the ground.
		local isLeft  = v.Name:find("Left")  ~= nil
		local isRight = v.Name:find("Right") ~= nil
		local spreadDist = math.random(35, 80) / 10  -- 3.5–8.0 studs outward
		local offsetY = -1.5  -- slight downward for ground-skimming look
		local offsetX, offsetZ

		if math.random() < 0.5 then
			-- Side-biased: follows which side the limb is on
			if isLeft then
				offsetX = -spreadDist
				offsetZ = (math.random() - 0.5) * 3
			elseif isRight then
				offsetX = spreadDist
				offsetZ = (math.random() - 0.5) * 3
			else
				-- Centre parts: random flat direction
				local ang = math.random() * math.pi * 2
				offsetX = math.cos(ang) * spreadDist
				offsetZ = math.sin(ang) * spreadDist
			end
		else
			-- 50 % chance: fully random horizontal direction (no up/down)
			local ang = math.random() * math.pi * 2
			offsetX = math.cos(ang) * spreadDist
			offsetZ = math.sin(ang) * spreadDist
		end

		a0.Position = Vector3.new(0, 0, 0)
		a1.Position = Vector3.new(offsetX, offsetY, offsetZ)

		local x = Instance.new("Trail")
		x.Attachment0 = a0
		x.Attachment1 = a1
		x.Brightness = 1
		x.FaceCamera = false
		x.LightEmission = 1
		x.LightInfluence = 1
		x.Lifetime = 0.4
		x.MaxLength = 0
		x.MinLength = 0.1
		x.Color = col
		x.Transparency = NumberSequence.new(0)
		x.WidthScale = wsSeq
		x.Enabled = false
		x.Parent = v

		tlist[#tlist+1] = x
	end
end

