-- ================================================================
-- MASTER DISABLE FUNCTION
-- Called by all stop paths to guarantee a clean shutdown every time.
-- Fixes the "doesn't properly disable" bug: all trail tables and
-- all dynamic systems are stopped in a single deterministic sequence.
-- ================================================================
local function MasterDisableAll()
    -- 1. Stop dynamic systems FIRST (they may be enabling trails)
    StopLightningFlicker()
    StopGroundArcs()

    -- 2. Stop the particle effect system
    StopEffect()

    -- 3. Disable ALL trail tables explicitly
    V88()   -- t trails
    V90()   -- tlist trails
    DisableCoolStuff()   -- allTrails
    DisableLightningGlobal()   -- particle emitter on HRP

    -- 4. Stop running connections
    if runningConnection then
        runningConnection:Disconnect()
        runningConnection = nil
    end
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end

    -- 5. Disable the enableAll system (TrailsPerPart + animations + sounds)
    disableRunEvents()
    disableAll()

    -- 6. Nuclear sound kill — catches anything disableAll missed due to state desync,
    --    early-returns, or sounds restarted by the leaked walkspeed heartbeat
    StopAllPlayerSounds()

    -- 7. Reset flags
    spd = false
    playerData.spd = false
end

