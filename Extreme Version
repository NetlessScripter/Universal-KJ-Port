-- ================================================================
-- LIGHTNING SYSTEM 2: DCEU GROUND ARC SYSTEM
--
-- Research basis:
-- DCEU Flash (Justice League, The Flash 2023): Lightning originates
-- FROM the speedster's core/torso and arcs DOWN to random ground
-- contact points. It doesn't just trail behind — it actively reaches
-- OUT and SNAPS to the ground like a Tesla coil discharge.
--
-- Unity/Unreal technique: Procedural noise-displaced line segments.
-- In Roblox equivalent: Beam instance with:
--   - High Segments count (10-24) = more control points = more jagged
--   - Random CurveSize0/CurveSize1 (positive AND negative values)
--     = S-curve deformation = zigzag lightning shape
--   - Very thin Width (0.03-0.15 studs) = realistic bolt thickness
--   - Very short Lifetime (30-180ms) = the "pop and vanish" feel
--   - ColorSequence: white core → speedster color → white tip
--
-- Raycast: fires from multiple body parts at slight downward angles
-- to find the ground. If it hits, places a temporary invisible anchor
-- part at the hit position, connects a Beam, then Debris cleans it up.
-- A secondary "branch" arc fires at 35% chance to simulate branching.
--
-- Bugs avoided:
-- - Position error: bodyAttach is parented to the part (not workspace)
--   so it moves with the character and needs no position updates
-- - groundAttach is at fixed world position (anchored part) so the
--   Beam naturally stretches as the character moves — looks correct
-- ================================================================

local groundArcActive = false
local groundArcThread = nil
local groundRayParams = RaycastParams.new()
groundRayParams.FilterType = Enum.RaycastFilterType.Exclude

-- Parts to arc FROM — prioritizes feet/legs (most visible ground contact)
-- then arms and hands, then torso as fallback
local GROUND_ARC_SOURCE_PARTS = {
    "LeftFoot", "RightFoot",
    "LeftLowerLeg", "RightLowerLeg",
    "Left Leg", "Right Leg",
    "LeftUpperLeg", "RightUpperLeg",
    "HumanoidRootPart",
    "UpperTorso", "LowerTorso", "Torso",
    "LeftHand", "RightHand",
    "LeftLowerArm", "RightLowerArm",
}

local Debris = game:GetService("Debris")

local function FireGroundArc(originPart, lightColor)
    if not originPart or not originPart.Parent then return end
    if not CharacterRef or not CharacterRef.Parent then return end
    if not HRP or not HRP.Parent then return end

    -- Update raycast exclusion list each call (character may have changed)
    groundRayParams.FilterDescendantsInstances = {CharacterRef}

    -- Variable spread: mostly downward, with horizontal deviation
    -- This makes lightning fan outward from feet rather than always going straight down
    local spreadX = (math.random() - 0.5) * 5
    local spreadZ = (math.random() - 0.5) * 5
    local rayLength = math.random(5, 20)
    local rayDir = Vector3.new(spreadX * 0.3, -rayLength, spreadZ * 0.3)

    local result = workspace:Raycast(originPart.Position, rayDir, groundRayParams)
    if not result then return end

    local groundPos = result.Position
    -- Slight random offset at ground contact = simulates lightning branching
    -- to a point slightly away from direct hit (like real ground strikes)
    groundPos = groundPos + Vector3.new(
        (math.random() - 0.5) * 2.5,
        0.02,  -- tiny upward offset so beam doesn't clip into floor
        (math.random() - 0.5) * 2.5
    )

    -- Temporary invisible anchor at ground position
    -- Anchored = true means it stays in world space while character moves
    -- This is intentional: the ground point is FIXED, the body end moves
    -- This creates the "lightning stretching as you run past" feel
    local groundPart = Instance.new("Part")
    groundPart.Anchored = true
    groundPart.CanCollide = false
    groundPart.CastShadow = false
    groundPart.Transparency = 1
    groundPart.Size = Vector3.new(0.05, 0.05, 0.05)
    groundPart.Position = groundPos
    groundPart.Parent = workspace

    local groundAttach = Instance.new("Attachment", groundPart)

    -- Body attachment with small random offset from part center
    -- Simulates lightning originating from different points on the limb
    local bodyAttach = Instance.new("Attachment", originPart)
    bodyAttach.Position = Vector3.new(
        (math.random() - 0.5) * 0.6,
        (math.random() - 0.5) * 0.5,
        (math.random() - 0.5) * 0.4
    )

    local whiteColor = Color3.new(1, 1, 1)

    -- === MAIN BEAM ARC ===
    local beam = Instance.new("Beam")
    beam.Attachment0 = bodyAttach   -- body end (moves with character)
    beam.Attachment1 = groundAttach  -- ground end (fixed)
    beam.FaceCamera = true
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Brightness = math.random(6, 14)
    -- Segments: more = more control points = more jagged zigzag path
    -- 10-24 gives good DCEU-style jaggedness without performance issues
    beam.Segments = math.random(10, 24)
    -- Width: very thin for realistic bolt appearance
    beam.Width0 = math.random(4, 14) / 100   -- origin end (body) slightly thicker
    beam.Width1 = math.random(1, 7) / 100    -- ground end thinner (tapers to point)
    -- CurveSize: THIS IS THE KEY TO JAGGEDNESS
    -- Positive + negative values on the two ends create an S-curve.
    -- Beam then interpolates across Segments creating the zigzag.
    -- Larger absolute values = more extreme zigzag.
    beam.CurveSize0 = (math.random() - 0.5) * 7
    beam.CurveSize1 = (math.random() - 0.5) * 7
    beam.Texture = "rbxassetid://16607923"  -- lightning bolt texture (from trailProps1)
    beam.TextureLength = math.random(1, 4)
    beam.TextureMode = Enum.TextureMode.Static
    -- Color: white core → speedster color → white tip (matches DCEU look)
    beam.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, whiteColor),
        ColorSequenceKeypoint.new(0.25, lightColor),
        ColorSequenceKeypoint.new(0.75, lightColor),
        ColorSequenceKeypoint.new(1, whiteColor)
    })
    -- Transparency: mostly opaque in middle, fades at ends
    beam.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.15),
        NumberSequenceKeypoint.new(0.4, 0),
        NumberSequenceKeypoint.new(0.6, 0),
        NumberSequenceKeypoint.new(1, 0.6)
    })
    beam.Parent = groundPart

    -- Lifetime: 30ms–180ms. The wide range gives unpredictable "pop" timing.
    -- Short bolts feel like sharp cracks; longer ones feel like sustained arcs.
    local lifetime = math.random(3, 18) / 100

    -- Schedule cleanup
    Debris:AddItem(groundPart, lifetime + 0.08)
    Debris:AddItem(bodyAttach, lifetime + 0.08)

    -- Fade-out tween: starts at 40% of lifetime, finishes by end
    -- This creates the "lightning dissipates" effect rather than hard-cutting
    task.delay(lifetime * 0.35, function()
        if beam and beam.Parent then
            ts:Create(beam, TweenInfo.new(lifetime * 0.65, Enum.EasingStyle.Expo, Enum.EasingDirection.Out), {
                Transparency = NumberSequence.new(1),
                Width0 = 0,
                Width1 = 0
            }):Play()
        end
    end)

    -- === BRANCH ARC (35% chance) ===
    -- Secondary thinner bolt that fires from same origin to a nearby ground point
    -- Simulates lightning branching — the single most recognizable DCEU Flash trait
    if math.random() < 0.35 and not _G.G_Optimized then
        task.delay(math.random(1, 3) / 100, function()  -- tiny delay so branch appears slightly after main
            if not CharacterRef or not CharacterRef.Parent then return end
            if not originPart or not originPart.Parent then return end

            local branchPart = Instance.new("Part")
            branchPart.Anchored = true
            branchPart.CanCollide = false
            branchPart.CastShadow = false
            branchPart.Transparency = 1
            branchPart.Size = Vector3.new(0.05, 0.05, 0.05)
            -- Branch lands at a different spot from the main arc
            branchPart.Position = groundPos + Vector3.new(
                (math.random() - 0.5) * 4,
                0.02,
                (math.random() - 0.5) * 4
            )
            branchPart.Parent = workspace

            local bAttach0 = Instance.new("Attachment", originPart)
            bAttach0.Position = bodyAttach.Position + Vector3.new(
                (math.random() - 0.5) * 0.4, 0, 0
            )
            local bAttach1 = Instance.new("Attachment", branchPart)

            local branchBeam = Instance.new("Beam")
            branchBeam.Attachment0 = bAttach0
            branchBeam.Attachment1 = bAttach1
            branchBeam.FaceCamera = true
            branchBeam.LightEmission = 1
            branchBeam.LightInfluence = 0
            branchBeam.Brightness = math.random(3, 8)
            branchBeam.Segments = math.random(6, 16)
            -- Branches are thinner than main arc
            branchBeam.Width0 = math.random(1, 6) / 100
            branchBeam.Width1 = math.random(1, 3) / 100
            branchBeam.CurveSize0 = (math.random() - 0.5) * 5
            branchBeam.CurveSize1 = (math.random() - 0.5) * 5
            branchBeam.Texture = "rbxassetid://16607923"
            branchBeam.TextureLength = 2
            branchBeam.TextureMode = Enum.TextureMode.Static
            branchBeam.Color = ColorSequence.new(lightColor, whiteColor)
            branchBeam.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.4),
                NumberSequenceKeypoint.new(0.5, 0.1),
                NumberSequenceKeypoint.new(1, 1)
            })
            branchBeam.Parent = branchPart

            local bLifetime = lifetime * 0.55
            Debris:AddItem(branchPart, bLifetime + 0.05)
            Debris:AddItem(bAttach0, bLifetime + 0.05)

            ts:Create(branchBeam, TweenInfo.new(bLifetime, Enum.EasingStyle.Expo, Enum.EasingDirection.Out), {
                Transparency = NumberSequence.new(1),
                Width0 = 0,
                Width1 = 0
            }):Play()
        end)
    end
end

local function StartGroundArcs()
    if groundArcActive then return end
    groundArcActive = true

    -- Build available source parts list (only parts that actually exist on this character)
    local arcPartsList = {}
    for _, name in ipairs(GROUND_ARC_SOURCE_PARTS) do
        local p = CharacterRef:FindFirstChild(name)
        if p and p:IsA("BasePart") then
            table.insert(arcPartsList, p)
        end
    end
    if #arcPartsList == 0 then
        table.insert(arcPartsList, HRP)
    end

    groundArcThread = task.spawn(function()
        while groundArcActive and CharacterRef and CharacterRef.Parent do
            local isMoving = h and h.Parent and h.MoveDirection.Magnitude > 0
            local speed = h and h.Parent and h.WalkSpeed or 0

            if speed > 30 then
                local lightColor = GetLightningColor()

                if isMoving then
                    -- Running: fire 1-4 simultaneous arcs from random body parts
                    -- G_Optimized: always 1 arc; Normal: 1-3 arcs
                    local numArcs = _G.G_Optimized and 1 or math.random(1, 3)
                    for i = 1, numArcs do
                        local part = arcPartsList[math.random(1, #arcPartsList)]
                        -- Each arc is spawned independently so they don't block each other
                        task.spawn(FireGroundArc, part, lightColor)
                    end
                else
                    -- Standing still at high speed: occasional single torso arc
                    -- Simulates the "idle lightning crackling" seen in DCEU scenes
                    if math.random() < 0.35 then
                        task.spawn(FireGroundArc, HRP, lightColor)
                    end
                end
            end

            -- Arc interval scales with speed:
            -- At full speed (375): fires every ~30-70ms = ~15-30 arcs/second
            -- At low speed (100): fires every ~60-110ms = ~9-16 arcs/second
            -- G_Optimized: fires every ~80-150ms regardless of speed
            local interval
            if _G.G_Optimized then
                interval = math.random(8, 15) / 100
            else
                local speedFactor = math.clamp(speed / 375, 0, 1)
                local minMs = math.floor(3 + (1 - speedFactor) * 4)
                local maxMs = math.floor(7 + (1 - speedFactor) * 7)
                interval = math.random(minMs, maxMs) / 100
            end
            task.wait(interval)
        end
        groundArcActive = false
    end)
end

local function StopGroundArcs()
    groundArcActive = false
    if groundArcThread then
        task.cancel(groundArcThread)
        groundArcThread = nil
    end
end

