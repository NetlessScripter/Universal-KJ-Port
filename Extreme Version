-- ================================================================
-- LIGHTNING SYSTEM 1: DYNAMIC TRAIL FLICKER ENGINE
--
-- Research basis: DCEU/Arrowverse Flash lightning is "barely contained
-- energy". Each limb group crackles at its own rhythm — legs are most
-- active (ground contact), arms flicker mid-rate, torso most stable.
-- The key is ASYMMETRY and IRREGULARITY. Real lightning never pulses
-- uniformly. It snaps on/off at different times across the body.
--
-- Implementation:
-- - Three independent flicker loops run on offset timers
-- - Each loop owns a "group" of body-part trails
-- - Lifetime varies per tick (shorter = crisper, longer = smoother)
-- - math.sin wave + random spike = organic non-repeating pattern
-- - When G_Optimized: slower intervals, higher on-chance (less spam)
-- ================================================================

local flickerActive = false
local flickerThread = nil

local function StartLightningFlicker()
    if flickerActive then return end
    flickerActive = true

    flickerThread = task.spawn(function()
        local tick_leg = 0
        local tick_arm = 7  -- offset so arms and legs don't sync
        local tick_all = 3  -- offset for allTrails

        while flickerActive do
            tick_leg += 1
            tick_arm += 1
            tick_all += 1

            local speed = (h and h.Parent and h.WalkSpeed) or 0
            -- intensity: 0.2 at idle (lightning still crackles slightly), 1.0 at full speed
            local intensity = math.clamp(speed / math.max(customSpeed, 1), 0.2, 1.0)

            -- === tlist: BASE body trails - the most visible layer ===
            -- These are the trails from the simple loop at the top of setup.
            -- They flicker fast and form the "electricity wrapping the body" look.
            for idx, trail in ipairs(tlist) do
                if trail and trail.Parent then
                    -- Sine wave base creates a slow pulse, random spikes create jitter
                    local sineWave = math.sin(tick_leg * 0.4 + idx * 0.9) * 0.25 + 0.75
                    local rand = math.random()
                    if rand < intensity * sineWave then
                        trail.Enabled = true
                        -- Vary lifetime: short = sharp bolt feel, long = glow trail feel
                        -- Mix both for that DCEU "energy crackling with spikes" look
                        if rand < 0.15 then
                            trail.Lifetime = math.random(5, 10) / 100   -- short crackle spike
                        else
                            trail.Lifetime = math.random(12, 28) / 100  -- normal trail
                        end
                    elseif rand < (0.08 * intensity) then
                        -- Snap-off: this is the "lightning bolt pops" effect
                        -- A small percentage of the time, a trail turns off completely
                        -- creating the visual of a bolt vanishing and reappearing
                        trail.Enabled = false
                    end
                    -- else: leave as-is (no unnecessary writes)
                end
            end

            -- === t trails: SECONDARY lightning layer ===
            -- These use the lightning texture and are slightly slower to flicker
            -- creating a layered depth effect (fast crackle on top of slower glow)
            if tick_arm % 2 == 0 then
                for idx, trail in ipairs(t) do
                    if trail and trail.Parent then
                        local sineArm = math.sin(tick_arm * 0.3 + idx * 1.1) * 0.2 + 0.8
                        local rand = math.random()
                        if rand < intensity * sineArm * 0.9 then
                            trail.Enabled = true
                            trail.Lifetime = math.random(15, 40) / 100
                        elseif rand < 0.05 * intensity then
                            trail.Enabled = false
                        end
                    end
                end
            end

            -- === allTrails: THIRD layer (from createTrail) ===
            -- Slowest flicker rate — these provide the "corona glow" around limbs
            if tick_all % 3 == 0 then
                for idx, trail in ipairs(allTrails) do
                    if trail and trail.Parent then
                        if math.random() < intensity * 0.85 then
                            trail.Enabled = true
                        elseif math.random() < 0.04 then
                            trail.Enabled = false
                        end
                    end
                end
            end

            -- Dynamic wait: G_Optimized uses longer intervals
            task.wait(_G.G_Optimized and (math.random(4, 8) / 100) or (math.random(2, 5) / 100))
        end
    end)
end

local function StopLightningFlicker()
    flickerActive = false
    if flickerThread then
        task.cancel(flickerThread)
        flickerThread = nil
    end
    -- Note: caller is responsible for setting trails to correct enabled/disabled state
end

