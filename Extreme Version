-- ── tiny helpers ─────────────────────────────────────────────────
local function addGrad(parent, col, rot)
    local g = Instance.new("UIGradient")
    g.Color   = col
    g.Rotation = rot or 0
    g.Parent  = parent
    return g
end

local function addStrokeGrad(parent, thickness, col, rot)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    addGrad(s, col, rot or 45)
    s.Parent = parent
    return s
end

local function addShine(parent)
