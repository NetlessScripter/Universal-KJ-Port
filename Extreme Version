-- yPos      : Y offset inside panel
-- label     : button text
-- icon      : symbol prefix
-- bg0/bg1   : background gradient colours
-- sk0/sk1   : stroke glow colours
-- textCol   : text colour
local function makeBtn(yPos, label, icon, bg0, bg1, sk0, sk1, textCol)
    local f = Instance.new("Frame")
    f.Parent = panel
    f.Size   = UDim2.new(1, -16, 0, 44)
    f.Position = UDim2.new(0, 8, 0, yPos)
    f.BackgroundColor3 = bg0
    f.BorderSizePixel  = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 20)

    addGrad(f, ColorSequence.new({
        ColorSequenceKeypoint.new(0, bg0),
        ColorSequenceKeypoint.new(1, bg1),
    }), 130)

    addStrokeGrad(f, 1.5, ColorSequence.new({
        ColorSequenceKeypoint.new(0,   sk0),
        ColorSequenceKeypoint.new(0.5, sk1),
        ColorSequenceKeypoint.new(1,   sk0),
    }), 45)

    addShine(f)

    local b = Instance.new("TextButton")
    b.Parent = f
    b.Size   = UDim2.new(1, 0, 1, 0)
    b.BackgroundTransparency = 1
    b.Text   = icon .. "  " .. label
    b.TextColor3  = textCol
    b.TextScaled  = true
    b.Font        = Enum.Font.Michroma
    b.AutoButtonColor = false
    return f, b
end

