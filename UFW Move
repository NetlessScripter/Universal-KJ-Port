-- shared.loop: runs fn on Heartbeat (optionally capped to fps).
-- Returns a disconnect function; calling it from inside fn stops the loop.
local function v780(fn, fps)
    local conn
    local elapsed = 0
    conn = RunService.Heartbeat:Connect(function(dt)
        if fps then
            elapsed = elapsed + dt
            if elapsed < (1 / fps) then return end
            elapsed = 0
        end
        fn()
    end)
    local function disconnect()
        if conn then conn:Disconnect(); conn = nil end
    end
    return disconnect
end
