local function _EnabledAllVisuals(p)
    for _, v in pairs(p:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Beam") or v:IsA("Trail") or v:IsA("PointLight") then
            v.Enabled = true
        end
    end
end
local function _Lerp(a, b, t) return a + (b - a) * t end
local function _UnixConnection2(duration, callback, cancelCheck, onDone)
    local done, fired, startT = false, false, tick()
    table.insert(_tempFuncs, function(dt)
        done = startT + duration <= tick()
        if callback and (cancelCheck == nil or cancelCheck()) and not done then
            local alpha = (tick() - startT) / duration
            callback(alpha, dt, _Lerp(1, 0, alpha), tick() - startT)
        elseif not fired then
            fired = true
            if callback and done then callback(1, dt, 0, duration) end
            if onDone then onDone(1, dt, 0) end
            return true
        end
    end)
end

