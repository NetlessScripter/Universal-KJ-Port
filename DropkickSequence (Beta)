local function DropKickStartUpSpeedLines(data)
    local _char = data.char
    local _Bind = data.Bind
    local KJEffects = game.ReplicatedStorage.Resources.KJEffects
    local TweenService = game:GetService("TweenService")
    local RunService   = game:GetService("RunService")
    local Debris       = game:GetService("Debris")

    local function _EnableAllVisuals(parent)
        for _, desc in ipairs(parent:GetDescendants()) do
            if desc:IsA("ParticleEmitter") or desc:IsA("Beam") then desc.Enabled = true end
        end
    end
    local function _Lerp2(a, b, t) return a + (b - a) * t end
    local function _SetBeamTransparency(part, val)
        for _, d in ipairs(part:GetDescendants()) do
            if d:IsA("Beam") then d.Transparency = NumberSequence.new(val) end
        end
    end
    local function _SetBeamTextureSpeed(part, val)
        for _, d in ipairs(part:GetDescendants()) do
            if d:IsA("Beam") then d.TextureSpeed = val end
        end
    end
    local function _UnixConn(duration, callback, checkFn)
        local start = os.clock()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            local elapsed = os.clock() - start
            local alpha   = math.clamp(elapsed / duration, 0, 1)
            if checkFn and not checkFn() then conn:Disconnect(); return end
            callback(alpha)
            if elapsed >= duration then conn:Disconnect() end
        end)
    end

    local speedMain  = KJEffects.speedlinesandstuff:Clone()
    local _primaryPart = _char:FindFirstChild("PrimaryPart")
    local _baseCF = _primaryPart and _primaryPart.CFrame or CFrame.new(_char:GetPivot().Position)
    speedMain.CFrame = _baseCF * CFrame.new(-0.819, 6.149, -102.914)
    speedMain.Parent = workspace.Thrown

    local speedUnder = speedMain.thespeedthingunderultik
    speedUnder.CFrame = _baseCF * CFrame.new(-0.019, -2.95, 23.185)
    speedUnder.Parent = workspace.Thrown

    local bindEnded      = false
    local endSeqRun      = false

    local function EndBeamSequence()
        endSeqRun = true
        Debris:AddItem(speedMain,  4)
        Debris:AddItem(speedUnder, 4)
        local tn = Instance.new("NumberValue"); tn.Value = 0
        TweenService:Create(tn, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value=1}):Play()
        tn:GetPropertyChangedSignal("Value"):Connect(function()
            _SetBeamTransparency(speedMain,  tn.Value)
            _SetBeamTransparency(speedUnder, tn.Value)
        end)
        local sn = Instance.new("NumberValue"); sn.Value = 6
        TweenService:Create(sn, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value=0}):Play()
        sn:GetPropertyChangedSignal("Value"):Connect(function()
            _SetBeamTextureSpeed(speedMain,  sn.Value)
            _SetBeamTextureSpeed(speedUnder, sn.Value)
        end)
    end

    _SetBeamTransparency(speedMain,  1); _SetBeamTransparency(speedUnder, 1)
    _SetBeamTextureSpeed(speedMain,  6); _SetBeamTextureSpeed(speedUnder, 6)
    _UnixConn(1.5, function(alpha)
        _SetBeamTransparency(speedMain,  alpha)
        _SetBeamTransparency(speedUnder, alpha)
    end, function()
        if bindEnded then EndBeamSequence(); return false end
        return true
    end)
    task.delay(1.5, function()
        if bindEnded and not endSeqRun then EndBeamSequence(); return end
        if not bindEnded then
            _UnixConn(4.617, function(alpha)
                _SetBeamTransparency(speedMain,  alpha); _SetBeamTransparency(speedUnder, alpha)
                local spd = _Lerp2(6, 0, alpha)
                _SetBeamTextureSpeed(speedMain, spd); _SetBeamTextureSpeed(speedUnder, spd)
            end, function()
                if bindEnded then EndBeamSequence(); return false end
                return true
            end)
        end
    end)

    _EnableAllVisuals(speedMain)
    local tweenHandles = {}
    for _, child in ipairs(speedMain:GetChildren()) do
        if child:IsA("ParticleEmitter") then
            TweenService:Create(child, TweenInfo.new(0.95, Enum.EasingStyle.Quart, Enum.EasingDirection.InOut), {Rate=900}):Play()
            task.delay(0.95, function()
                local t = TweenService:Create(child, TweenInfo.new(3.75, Enum.EasingStyle.Linear), {Rate=0})
                t:Play(); table.insert(tweenHandles, t)
            end)
        end
    end

    local renderConn
    renderConn = RunService.RenderStepped:Connect(function()
        if _Bind and _Bind.Parent then
            local pp = _char:FindFirstChild("PrimaryPart")
            local cf = pp and pp.CFrame or CFrame.new(_char:GetPivot().Position)
            speedMain.CFrame  = cf * CFrame.new(-0.819, 6.149, -102.914)
            speedUnder.CFrame = cf * CFrame.new(-0.019, -2.95,  23.185)
        else
            bindEnded = true
            for i, t in pairs(tweenHandles) do table.remove(tweenHandles, i); t:Cancel() end
            for _, d in ipairs(speedMain:GetDescendants()) do
                if d:IsA("ParticleEmitter") then d.Enabled = false end
            end
            renderConn:Disconnect()
            Debris:AddItem(speedMain, 6)
        end
    end)
end

